			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;strong&gt;学术伦理&lt;/strong&gt;&lt;/td&gt;
					&lt;td&gt;不代写论文，不做学术造假&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;strong&gt;学校规定&lt;/strong&gt;&lt;/td&gt;
					&lt;td&gt;确认学校是否允许兼职/副业（部分学校需报备）&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;strong&gt;知识产权&lt;/strong&gt;&lt;/td&gt;
					&lt;td&gt;注意区分职务成果和个人成果&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;strong&gt;税务合规&lt;/strong&gt;&lt;/td&gt;
					&lt;td&gt;大额收入需报税，可注册个体户&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;strong&gt;精力管理&lt;/strong&gt;&lt;/td&gt;
					&lt;td&gt;建议先选 1-2 个方向深耕，不要同时铺开&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
